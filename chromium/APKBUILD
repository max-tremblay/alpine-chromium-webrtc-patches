options="suid"

case "$CARCH" in
riscv64)
	;;
*)
	# dbg outside riscv only
	subpackages="$pkgname-dbg $subpackages"
	;;
esac

case "$CARCH" in
x86_64|aarch64)
	;;
*)
	# 32-bit fails a bunch of tests for various size-related reasons
	options="$options !check"
	;;
esac

